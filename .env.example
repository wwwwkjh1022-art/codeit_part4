COPY_PROVIDER=auto
PUBLIC_BASE_URL=http://127.0.0.1:8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
MAX_GENERATION_ATTEMPTS=1

# Local SD3.5 endpoint is preferred for image generation. Keep OpenAI/Gemini paid APIs off by default.
IMAGE_PROVIDER=sd35
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_QUALITY=low
NAVER_BLOG_HEADLESS=true
NAVER_BLOG_SLOWMO_MS=0
NAVER_BLOG_TIMEOUT_MS=45000
SD35_API_KEY=
SD35_ENDPOINT_URL=http://127.0.0.1:8188/sd35/generate
SD35_MODEL=stabilityai/sdxl-turbo
SD35_WIDTH=1024
SD35_HEIGHT=768
SD35_STEPS=4
SD35_GUIDANCE_SCALE=2.0
SD35_FALLBACK_TO_LOCAL=true
ALLOW_PAID_IMAGE_GENERATION=false
